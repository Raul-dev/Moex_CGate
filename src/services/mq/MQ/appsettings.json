{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Debug",
        "Microsoft.AspNetCore": "Debug",
        "System": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "[{@t:HH:mm:ss.ff}] [{@l:u3}] {@m}\n{@x}"
          }
        }
      },

      {
        "Name": "File",
        "Args": {
          "path": "../logs/MQ-.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": "128000",
          "retainedFileCountLimit": 3,
          "formatter": {
            "type": "Serilog.Templates.ExpressionTemplate, Serilog.Expressions",
            "template": "{ {Timestamp: @t, Level: @l, Message: @m, Properties: @p} }\n"
            //"template": "[{@t:HH:mm:ss.ff}] [{@l:u3}] {@m} Context:{#if SourceContext is not null} [{SourceContext}]{#end}\n{@x}"
          }

        }
      }
    ],
    "Properties": {
      "Application": "MQ"
    }
  },
  
  "ServiceGetMsgSettings": {
    "ServiceName": "MQ",
    "ServiceDisplayName": "MQ Service",
    "ServiceDescription": "MQ Service for FORTS Trade Replication",
    "Services": [
      {
        "Name": "RabbitMQ",
        "IsEnabled": true,
        "LogPrefix": "RabbitMQ",
        "IsConfirmMsgAndRemoveFromQueue": "false",
        "Iteration": "100",
        "PauseMs": "1000",
        "RabbitMQSettings": {
          "Host": "localhost",
          "VirtualHost": "/",
          "Exchange": "amq.fanout",
          "Port": 5672,
          "UserName": "admin",
          "UserPassword": "admin",
          "DefaultQueue": "Cgate_FORTS_TRADE_REPL",
          "SslEnabled": "false",
          "SslServerName": "localhost",
          "SslVersion": "3072"

        },
        "DataBaseSettings": {
          "ServerName": "localhost",
          "Port": "54321",
          "ServerType": "mssql",
          "DataBase": "CGate",
          "ClientName": "CGate",
          "User": "CGateUser",
          "Password": "MyPassword321",
          "SessionMode": "FullMode"
        }
      },
      {
        "Name": "RabbitMQ",
        "IsEnabled": true,
        "LogPrefix": "RabbitMQ",
        "RabbitMQSettings": {
          "Host": "localhost",
          "VirtualHost": "/",
          "Exchange": "amq.fanout",
          "Port": 5672,
          "UserName": "admin",
          "UserPassword": "admin",
          "DefaultQueue": "Cgate_FORTS_TRADE_REPL",
          "SslEnabled": "false",
          "SslServerName": "localhost",
          "SslVersion": "3072"
        },
        "DataBaseSettings": {
          "ServerName": "localhost",
          "Port": "54321",
          "ServerType": "mssql",
          "DataBase": "CGate",
          "ClientName": "CGate",
          "User": "CGateUser",
          "Password": "MyPassword321",
          "SessionMode": "bufferonly"
        }

      },

      {
        "Name": "Kafka",
        "IsEnabled": false
      }
    ]
  },

  "RabbitMQSettings": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Exchange": "amq.fanout",
    "Port": 5672,
    "UserName": "admin",
    "UserPassword": "admin",
    "DefaultQueue": "Cgate_FORTS_TRADE_REPL",
    "SslEnabled": "false",
    "SslServerName": "localhost",
    "SslVersion": "3072"
  },
  "KafkaSettings": {
    "Host": "localhost",
    "Port": 9092,
    "Topic": "Cgate_FORTS_TRADE_REPL",
    "GroupId": "somegroup3"
  }
}
